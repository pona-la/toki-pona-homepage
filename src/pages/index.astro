---
import "@/styles/common.css";

import Layout2 from "@/layouts/Layout2.astro";
import HomepageLeft from "@/components/HomepageLeft.astro";
import HomepageRight from "@/components/HomepageRight.astro";
---

<Layout2
	title={"Toki Pona (Homepage)"}
	description={"Toki Pona: the language with only 120 words."}
>
	<section style='grid-area: right;'>
		<HomepageLeft />
	</section>
	<section style='grid-area: left;'>
		<HomepageRight />
	</section>
</Layout2>

<footer>
	Made by the Toki Pona community.<br />
	Source code is available on <a
		href='https://github.com/pona-la/toki-pona-homepage'>GitHub</a
	>.
</footer>
